# ─────────────────────────────────────────────────────────────────────────────
# Espace Médical SaaS — Variables d'environnement
# Copiez ce fichier en .env.local pour le développement local
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de données PostgreSQL ────────────────────────────────────────────────
DATABASE_URL="postgresql://medical_user:votre_mot_de_passe@localhost:5432/medical_db?schema=public"

# Variables séparées pour Docker Compose
POSTGRES_USER=medical_user
POSTGRES_PASSWORD=votre_mot_de_passe_fort
POSTGRES_DB=medical_db

# ── Authentification NextAuth (Auth.js v5) ────────────────────────────────────
# Générez une clé avec : openssl rand -base64 32
AUTH_SECRET="votre_clé_secrète_32_caractères_minimum"

# URL publique de l'application (sans slash final)
# En dev : http://localhost:3000
# En prod : https://medical.votre-domaine.com
AUTH_URL="http://localhost:3000"

# ── Google Cloud Vision API ───────────────────────────────────────────────────
# Créez un projet sur https://console.cloud.google.com
# Activez "Cloud Vision API" et créez une clé API
GOOGLE_VISION_API_KEY="AIzaSy..."

# ── Resend (Email) ─────────────────────────────────────────────────────────────
# Créez un compte sur https://resend.com
# Optionnel : si non configuré, les emails sont simplement ignorés
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@votre-domaine.com"

# ── Coolify (Traefik) — injecté automatiquement en production ──────────────────
# SERVICE_FQDN_APP=medical.votre-domaine.com
