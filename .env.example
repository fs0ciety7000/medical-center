# Ne commitez JAMAIS votre vrai fichier .env en production.
# Ce fichier sert de référence pour définir quelles variables sont requises dans Coolify.

# 1. Base de données
# L'URL de connexion Prisma (PostgreSQL)
# Sur Coolify, vous pouvez créer une ressource PostgreSQL et elle vous donnera une URL similaire.
DATABASE_URL="postgresql://user:password@localhost:5432/medical_db?schema=public"

# 2. Authentification (Auth.js v5)
# Requis en production. Générez une clé secrète avec la commande `npx auth secret` ou `openssl rand -base64 33`
AUTH_SECRET="your_generated_random_secret_here"
# Optionnel si vous n'êtes pas sur Vercel (NextAuth le déduit souvent, mais c'est bien de le forcer pour Coolify)
AUTH_URL="https://mon-saas-medical.com"

# 3. Google Cloud Vision (OCR)
# Clé API pour lire le texte des ordonnances manuscrites
GOOGLE_VISION_API_KEY="AIzaSyYourGoogleCloudVisionApiKeyHere"
